ble\" style=\"border-spacing: 0\" aria-label=\"ROC Association Statistics\">\n<caption aria-label=\"ROC Association Statistics\"></caption>\n<colgroup><col/></colgroup><colgroup><col/><col/><col/><col/><col/><col/><col/></colgroup>\n<thead>\n<tr>\n<th class=\"c b header\" colspan=\"8\" scope=\"colgroup\">ROC Association Statistics</th>\n</tr>\n<tr>\n<th class=\"b header\" rowspan=\"2\" scope=\"col\">ROC Model</th>\n<th class=\"c b header\" colspan=\"4\" scope=\"colgroup\">Mann-Whitney</th>\n<th class=\"r b header\" rowspan=\"2\" scope=\"col\">Somers&apos; D</th>\n<th class=\"r b header\" rowspan=\"2\" scope=\"col\">Gamma</th>\n<th class=\"r b header\" rowspan=\"2\" scope=\"col\">Tau-a</th>\n</tr>\n<tr>\n<th class=\"r b header\" scope=\"col\">Area</th>\n<th class=\"r b header\" scope=\"col\">Standard<br/>Error</th>\n<th class=\"c b header\" colspan=\"2\" scope=\"colgroup\">95% Wald<br/>Confidence Limits</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Ensemble</th>\n<td class=\"r data\">0.8135</td>\n<td class=\"r data\">0.0190</td>\n<td class=\"r data\">0.7763</td>\n<td class=\"r data\">0.8507</td>\n<td class=\"r data\">0.6270</td>\n<td class=\"r data\">0.6270</td>\n<td class=\"r data\">0.1262</td>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Logistic Regression</th>\n<td class=\"r data\">0.7371</td>\n<td class=\"r data\">0.0215</td>\n<td class=\"r data\">0.6949</td>\n<td class=\"r data\">0.7793</td>\n<td class=\"r data\">0.4742</td>\n<td class=\"r data\">0.4742</td>\n<td class=\"r data\">0.0954</td>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Gradient Boosting</th>\n<td class=\"r data\">0.8319</td>\n<td class=\"r data\">0.0168</td>\n<td class=\"r data\">0.7990</td>\n<td class=\"r data\">0.8649</td>\n<td class=\"r data\">0.6639</td>\n<td class=\"r data\">0.6639</td>\n<td class=\"r data\">0.1336</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"2370  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2371  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2372  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2373  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml110.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2374  %let _SASPROGRAMFILE =\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2374! %nrquote(%nrstr(/workspaces/churnproject/sas-education/sas1/03_Addressing_the_Use_Case_with_the_SAS_Language/03_Machine_Learni\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2374! ng/03_Developing_a_Model.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2375  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2376  proc logistic data=ensemble_predictions plots=roc;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2377     model &target(event='1') = log_pred grad_pred ensemble_pred / nofit;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2378     roc 'Ensemble' ensemble_pred;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"79                                                         The SAS System                       Friday, October  3, 2025 06:45:00 PM\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2379     roc 'Logistic Regression' log_pred;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2380     roc 'Gradient Boosting' grad_pred;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2381  run;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: The NOFIT option is specified.  No parameters are estimated and all other MODEL statement options (except EQUALSLOPES, FIRTH, \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      LINK=, NOINT, OFFSET=, TECHNIQUE=, and UNEQUALSLOPES) are ignored.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROC LOGISTIC is modeling the probability that LostCustomer='1'.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Convergence criterion (GCONV=1E-8) satisfied for Ensemble.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: HTML data tips have been disabled for at least one plot because the threshold has been reached. You can set TIPMAX=1500 in \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      the ODS GRAPHICS statement to produce data tips for all plots.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Convergence criterion (GCONV=1E-8) satisfied for Logistic Regression.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: HTML data tips have been disabled for at least one plot because the threshold has been reached. You can set TIPMAX=1500 in \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      the ODS GRAPHICS statement to produce data tips for all plots.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Convergence criterion (GCONV=1E-8) satisfied for Gradient Boosting.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: HTML data tips have been disabled for at least one plot because the threshold has been reached. You can set TIPMAX=1500 in \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      the ODS GRAPHICS statement to produce data tips for all plots.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: HTML data tips have been disabled for at least one plot because the threshold has been reached. You can set TIPMAX=4500 in \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      the ODS GRAPHICS statement to produce data tips for all plots.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: There were 1499 observations read from the data set WORK.ENSEMBLE_PREDICTIONS.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE LOGISTIC used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           1.10 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.46 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2382  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"2383  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":1,"language":"markdown","value":"## Additional Model Assessment\n\nCreate macro program Modelstats that calculates accuracy, sensitivity, and specificity for all three models including ensemble.","outputs":[]},{"kind":2,"language":"sas","value":"%macro modelstats(mtype);\n\n/* Run PROC FREQ to generate the frequency table */\nproc freq data=ensemble_predictions noprint;\n  tables &target*I_&target._&mtype / out=freq_out;\nrun;\n\n/* Extract the counts for TP, TN, FP, FN and save to a new dataset */\ndata confusion_matrix;\n    length TP TN FP FN 8;\n    set freq_out;\n\n    /* Initialize counts */\n    retain TP TN FP FN 0;\n\n    /* True Positive: actual=1 and predicted=1 */\n    if &target = 1 and I_&target._&mtype = \"1\" then TP = count;\n\n    /* True Negative: actual=0 and predicted=0 */\n    if &target = 0 and I_&target._&mtype = \"0\" then TN = count;\n\n    /* False Positive: actual=0 and predicted=1 */\n    if &target = 0 and I_&target._&mtype = \"1\" then FP = count;\n\n    /* False Negative: actual=1 and predicted=0 */\n    if &target = 1 and I_&target._&mtype = \"0\" then FN = count;\n\n    /* Keep only one row with the final values */\n    if _N_ = 4 then output;\n    keep TP TN FP FN;\nrun;\n\ndata metrics;\n    set confusion_matrix;\n    Accuracy = (TP + TN) / (TP + TN + FP + FN);\n    Sensitivity = TP / (TP + FN);\n    Specificity = TN / (TN + FP);\nrun;\n\nTitle2 \"Overall Model Perfomance Statistics for &mtype\";\nproc print data=metrics;\nrun;\n%mend modelstats;\n\n%modelstats(log)\n%modelstats(grad)\n%modelstats(ensemble)\n\n/* Clean up */\ntitle;\nfootnote;","outputs":[{"items":[{"data":"<!DOCTYPE html>\n<html lang=\"en\" xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta content=\"SAS V.04.00\" name=\"generator\"/>\n<title>SAS Output</title>\n<style>\n/*<![CDATA[*/\n.body.c > table, .body.c > pre, .body.c div > table,\n.body.c div > pre, .body.c > table, .body.c > pre,\n.body.j > table, .body.j > pre, .body.j div > table,\n.body.j div > pre, .body.j > table, .body.j > pre,\n.body.c p.note, .body.c p.warning, .body.c p.error, .body.c p.fatal,\n.body.j p.note, .body.j p.warning, .body.j p.error, .body.j p.fatal,\n.body.c > table.layoutcontainer, .body.j > table.layoutcontainer { margin-left: auto; margin-right: auto }\n.layoutregion.